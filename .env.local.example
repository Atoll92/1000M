# --- Sanity ---------------------------------------------------------------
# Leave PROJECT_ID blank to run the site on the bundled /content data (fully
# static, no connection needed). Fill it in to point every getter in
# lib/source.ts at Sanity and to connect the /admin Studio.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Optional: a read token enables fresh (uncached) reads / draft preview.
SANITY_API_READ_TOKEN=
