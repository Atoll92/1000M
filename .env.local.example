# --- Sanity ---------------------------------------------------------------
# PROJECT_ID connects the embedded /admin Studio. Leave it blank to run fully
# static with no connection.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# The public site keeps serving bundled /content even when the Studio is
# connected. Set to true (with a seeded dataset) to make lib/source.ts read
# live from Sanity.
NEXT_PUBLIC_USE_SANITY=false

# Optional: a read token enables fresh (uncached) reads / draft preview.
SANITY_API_READ_TOKEN=
