# --- Sanity ---------------------------------------------------------------
# Leave these blank to run the site on bundled demo content (lib/demo.ts).
# Fill them in to connect a real Sanity project + the /admin Studio.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Optional: a read token enables fresh (uncached) reads / draft preview.
SANITY_API_READ_TOKEN=

# --- Mux (optional) -------------------------------------------------------
# Only needed if you upload from the Studio via sanity-plugin-mux-input.
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
